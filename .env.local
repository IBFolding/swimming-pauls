# Swimming Pauls - Ollama Local Config
# Uses local LLM for 100% offline operation

LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3-coder:latest
OLLAMA_URL=http://localhost:11434

# Paul's World Settings
PAUL_COUNT=100
ROUNDS=5
ENABLE_PAPER_TRADING=true
INITIAL_BALANCE=10000

# Data feeds (local skills only)
ENABLE_MARKET_DATA=true
ENABLE_NEWS_FEED=true
ENABLE_BLOCKCHAIN_DATA=true

# Runtime settings
LOG_LEVEL=INFO
SAVE_INTERVAL=300
